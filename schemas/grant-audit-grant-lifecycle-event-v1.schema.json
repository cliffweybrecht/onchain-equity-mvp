{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grant-audit-grant-lifecycle-event-v1.schema.json",
  "title": "Grant Audit Grant Lifecycle Event V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "event_version",
    "grant_id",
    "event_id",
    "event_type",
    "effective_at",
    "current_state",
    "lifecycle_lineage_hash",
    "trust_chain_hash",
    "quantity_normalization",
    "event_hash"
  ],
  "properties": {
    "schema": {
      "const": "grant-audit-grant-lifecycle-event-v1"
    },
    "event_version": {
      "type": "string"
    },
    "grant_id": {
      "type": "string",
      "minLength": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "effective_at": {
      "type": "string",
      "format": "date-time"
    },
    "current_state": {
      "type": "string",
      "minLength": 1
    },
    "previous_state": {
      "type": ["string", "null"]
    },
    "quantity": {
      "type": ["string", "null"],
      "pattern": "^[0-9]+$"
    },
    "metadata": {
      "type": "object"
    },
    "lifecycle_lineage_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "trust_chain_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "quantity_normalization": {
      "$ref": "grant-audit-lifecycle-quantity-normalization-v1.schema.json"
    },
    "event_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
