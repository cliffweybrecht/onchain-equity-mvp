{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grant-audit-grant-lifecycle-event-v1.schema.json",
  "title": "Grant Audit Grant Lifecycle Event V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "event_version",
    "event_type",
    "recorded_at",
    "grant_id",
    "lifecycle_event_id",
    "event_sequence",
    "effective_at",
    "state_transition",
    "quantity",
    "consideration",
    "references",
    "lifecycle_anchor_lineage_reference",
    "deterministic_hashes"
  ],
  "properties": {
    "schema": {
      "const": "grant-audit-grant-lifecycle-event-v1"
    },
    "event_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "vesting",
        "cancellation",
        "settlement",
        "exercise",
        "transfer_state_change",
        "repurchase",
        "forfeiture",
        "manual_adjustment"
      ]
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "grant_id": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "effective_at": {
      "type": "string",
      "format": "date-time"
    },
    "state_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_state",
        "to_state",
        "reason_code"
      ],
      "properties": {
        "from_state": {
          "type": "string",
          "minLength": 1
        },
        "to_state": {
          "type": "string",
          "minLength": 1
        },
        "reason_code": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit",
        "delta"
      ],
      "properties": {
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "delta": {
          "type": [
            "string",
            "number",
            "integer"
          ]
        },
        "post_event_balance": {
          "type": [
            "string",
            "number",
            "integer"
          ]
        }
      }
    },
    "consideration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "amount"
      ],
      "properties": {
        "currency": {
          "type": "string",
          "minLength": 1
        },
        "amount": {
          "type": [
            "string",
            "number",
            "integer"
          ]
        },
        "price_per_unit": {
          "type": [
            "string",
            "number",
            "integer"
          ]
        }
      }
    },
    "references": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "grant_document_uri": {
          "type": "string"
        },
        "cap_table_entry_id": {
          "type": "string"
        },
        "settlement_reference_id": {
          "type": "string"
        },
        "exercise_notice_id": {
          "type": "string"
        },
        "transfer_reference_id": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "lifecycle_anchor_lineage_reference": {
      "type": "object"
    },
    "deterministic_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifecycle_event_hash",
        "lifecycle_lineage_hash",
        "trust_chain_hash",
        "artifact_hash"
      ],
      "properties": {
        "lifecycle_event_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "lifecycle_lineage_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "trust_chain_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "artifact_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
