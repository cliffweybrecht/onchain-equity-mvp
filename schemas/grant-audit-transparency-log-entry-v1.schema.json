{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grant-audit-transparency-log-entry-v1.schema.json",
  "title": "Grant Audit Transparency Log Entry v1",
  "type": "object",
  "required": [
    "schema",
    "entry_version",
    "index",
    "appended_at",
    "entry_hash",
    "cumulative_root"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "grant-audit-transparency-log-entry-v1"
    },
    "entry_version": {
      "type": "string"
    },
    "index": {
      "type": "integer",
      "minimum": 0
    },
    "appended_at": {
      "type": "string",
      "format": "date-time"
    },
    "entry_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "cumulative_root": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}
