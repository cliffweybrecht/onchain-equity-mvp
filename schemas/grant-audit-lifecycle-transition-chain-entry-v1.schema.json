{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grant-audit-lifecycle-transition-chain-entry-v1.schema.json",
  "title": "Grant Audit Lifecycle Transition Chain Entry V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "entry_version",
    "index",
    "grant_id",
    "event_id",
    "event_type",
    "effective_at",
    "previous_state",
    "current_state",
    "event_hash",
    "normalized_quantities",
    "lifecycle_lineage_hash",
    "trust_chain_hash",
    "prev_entry_hash",
    "entry_hash"
  ],
  "properties": {
    "schema": {
      "const": "grant-audit-lifecycle-transition-chain-entry-v1"
    },
    "entry_version": {
      "type": "string"
    },
    "index": {
      "type": "integer",
      "minimum": 0
    },
    "grant_id": {
      "type": "string",
      "minLength": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "effective_at": {
      "type": "string",
      "format": "date-time"
    },
    "previous_state": {
      "type": ["string", "null"]
    },
    "current_state": {
      "type": "string",
      "minLength": 1
    },
    "event_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "normalized_quantities": {
      "$ref": "grant-audit-lifecycle-quantity-normalization-v1.schema.json"
    },
    "lifecycle_lineage_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "trust_chain_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "prev_entry_hash": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "entry_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
