{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grant-audit-transparency-issuance-anchor-reference-v1.schema.json",
  "title": "Transparency Issuance Anchor Reference",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "reference_version",
    "issuance_anchor_path",
    "issuance_anchor_schema",
    "issuance_anchor_hash",
    "checkpoint_finalization_path",
    "checkpoint_finalization_schema",
    "checkpoint_finalization_hash",
    "finalized_checkpoint_hash",
    "transparency_log_root",
    "onchain_root_anchor"
  ],
  "properties": {
    "schema": {
      "const": "grant-audit-transparency-issuance-anchor-reference-v1"
    },
    "reference_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "issuance_anchor_path": {
      "type": "string",
      "minLength": 1
    },
    "issuance_anchor_schema": {
      "type": "string",
      "minLength": 1
    },
    "issuance_anchor_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "checkpoint_finalization_path": {
      "type": "string",
      "minLength": 1
    },
    "checkpoint_finalization_schema": {
      "type": "string",
      "minLength": 1
    },
    "checkpoint_finalization_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "finalized_checkpoint_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "transparency_log_root": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "onchain_root_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chain_id",
        "block_number",
        "tx_hash"
      ],
      "properties": {
        "network": {
          "type": "string",
          "minLength": 1
        },
        "chain_id": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "pattern": "^[0-9]+$" }
          ]
        },
        "block_number": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^[0-9]+$" }
          ]
        },
        "tx_hash": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}
