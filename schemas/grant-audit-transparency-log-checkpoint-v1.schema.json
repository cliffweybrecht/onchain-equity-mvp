{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grant-audit-transparency-log-checkpoint-v1.schema.json",
  "title": "Grant Audit Transparency Log Checkpoint v1",
  "type": "object",
  "required": [
    "schema",
    "checkpoint_version",
    "created_at",
    "log_path",
    "log_version",
    "entry_count",
    "head_entry_hash",
    "head_entry_cumulative_root",
    "log_root"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "grant-audit-transparency-log-checkpoint-v1"
    },
    "checkpoint_version": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "log_path": {
      "type": "string"
    },
    "log_version": {
      "type": "string"
    },
    "entry_count": {
      "type": "integer",
      "minimum": 0
    },
    "head_entry_hash": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "head_entry_cumulative_root": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "log_root": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
