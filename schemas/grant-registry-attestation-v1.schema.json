{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grant-registry-attestation-v1.schema.json",
  "title": "Grant Registry Attestation V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "registryHash",
    "merkleRoot",
    "network",
    "blockNumber",
    "timestamp",
    "attestor",
    "signature"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Relative path to this schema file."
    },
    "schemaVersion": {
      "type": "string",
      "const": "grant-registry-attestation-v1"
    },
    "registryHash": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$",
      "description": "sha256(canonical_json(registry.json)) as 32-byte hex."
    },
    "merkleRoot": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$",
      "description": "Merkle root from manifests/grants/merkle-root.json (32-byte hex)."
    },
    "network": {
      "type": "string",
      "minLength": 1
    },
    "blockNumber": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp (seconds) from the referenced block."
    },
    "attestor": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$",
      "description": "Ethereum address that produced the signature."
    },
    "signature": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{130}$",
      "description": "65-byte ECDSA signature over the sha256 digest (Ethereum-compatible secp256k1)."
    }
  }
}
