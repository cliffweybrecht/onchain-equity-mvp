{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Grant Audit Attestation Bundle Integrity V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "created_at",
    "packet_manifest_hash",
    "files"
  ],
  "properties": {
    "schema": {
      "const": "grant-audit-attestation-bundle-integrity-v1"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "packet_manifest_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "files": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "path", "sha256"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
