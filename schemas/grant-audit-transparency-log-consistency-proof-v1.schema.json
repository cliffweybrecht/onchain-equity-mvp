{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grant-audit-transparency-log-consistency-proof-v1.schema.json",
  "title": "Grant Audit Transparency Log Consistency Proof v1",
  "type": "object",
  "required": [
    "schema",
    "proof_version",
    "created_at",
    "log_path",
    "old_size",
    "new_size",
    "old_root",
    "new_root",
    "old_head_entry_hash",
    "new_head_entry_hash",
    "old_tail_index",
    "new_tail_index",
    "old_tail_cumulative_root",
    "new_tail_cumulative_root",
    "prefix_entry_hashes"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "grant-audit-transparency-log-consistency-proof-v1"
    },
    "proof_version": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "log_path": {
      "type": "string"
    },
    "old_size": {
      "type": "integer",
      "minimum": 1
    },
    "new_size": {
      "type": "integer",
      "minimum": 1
    },
    "old_root": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "new_root": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "old_head_entry_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "new_head_entry_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "old_tail_index": {
      "type": "integer",
      "minimum": 0
    },
    "new_tail_index": {
      "type": "integer",
      "minimum": 0
    },
    "old_tail_cumulative_root": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "new_tail_cumulative_root": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "prefix_entry_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    }
  },
  "additionalProperties": false
}
