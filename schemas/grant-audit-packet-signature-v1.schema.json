{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grant-audit-packet-signature-v1.schema.json",
  "title": "Grant Audit Packet Signature v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "signature_algorithm",
    "packet_manifest_hash",
    "signer",
    "signature",
    "signed_at"
  ],
  "properties": {
    "schema": {
      "const": "grant-audit-packet-signature-v1"
    },
    "signature_algorithm": {
      "const": "ed25519"
    },
    "packet_manifest_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "signer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key_id",
        "public_key_pem"
      ],
      "properties": {
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "public_key_pem": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "signature": {
      "type": "string",
      "contentEncoding": "base64",
      "pattern": "^[A-Za-z0-9+/]+={0,2}$"
    },
    "signed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
