{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grant-audit-transparency-checkpoint-finalization-v1.schema.json",
  "title": "Grant Audit Transparency Checkpoint Finalization v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "artifact_version",
    "created_at",
    "finalized_at",
    "checkpoint",
    "signing_payload",
    "finalization_policy",
    "quorum_status",
    "verified_witnesses"
  ],
  "properties": {
    "schema": {
      "const": "grant-audit-transparency-checkpoint-finalization-v1"
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "finalized_at": {
      "type": "string",
      "format": "date-time"
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "checkpoint_hash",
        "checkpoint_created_at",
        "entry_count",
        "log_root",
        "cumulative_root"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "checkpoint_created_at": {
          "type": "string",
          "format": "date-time"
        },
        "entry_count": {
          "type": "integer",
          "minimum": 0
        },
        "log_root": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "cumulative_root": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "signing_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "payload_version",
        "canonicalization",
        "hash_algorithm",
        "payload_hash"
      ],
      "properties": {
        "schema": {
          "const": "grant-audit-transparency-checkpoint-witness-signing-payload-v1"
        },
        "payload_version": {
          "type": "string",
          "const": "1.0.0"
        },
        "canonicalization": {
          "type": "string",
          "const": "deterministic-recursive-key-sorted-json"
        },
        "hash_algorithm": {
          "type": "string",
          "const": "SHA-256"
        },
        "payload_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "finalization_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "policy_version",
        "policy_path",
        "policy_hash",
        "threshold",
        "eligible_witness_count",
        "authorized_witnesses"
      ],
      "properties": {
        "schema": {
          "const": "grant-audit-transparency-checkpoint-finalization-policy-v1"
        },
        "policy_version": {
          "type": "string",
          "const": "1.0.0"
        },
        "policy_path": {
          "type": "string",
          "minLength": 1
        },
        "policy_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "threshold": {
          "type": "integer",
          "minimum": 1
        },
        "eligible_witness_count": {
          "type": "integer",
          "minimum": 1
        },
        "authorized_witnesses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "witness_id",
              "display_name",
              "public_key_pem_path",
              "public_key_fingerprint_sha256"
            ],
            "properties": {
              "witness_id": {
                "type": "string",
                "minLength": 1
              },
              "display_name": {
                "type": "string",
                "minLength": 1
              },
              "public_key_pem_path": {
                "type": "string",
                "minLength": 1
              },
              "public_key_fingerprint_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          }
        }
      }
    },
    "quorum_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "satisfied",
        "required_witness_count",
        "verified_witness_count",
        "eligible_witness_count",
        "verified_witness_ids",
        "missing_witness_ids"
      ],
      "properties": {
        "satisfied": {
          "type": "boolean"
        },
        "required_witness_count": {
          "type": "integer",
          "minimum": 1
        },
        "verified_witness_count": {
          "type": "integer",
          "minimum": 0
        },
        "eligible_witness_count": {
          "type": "integer",
          "minimum": 1
        },
        "verified_witness_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "missing_witness_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verified_witnesses": {
      "type": "array",
      "items": {
        "$ref": "grant-audit-transparency-witness-signature-v1.schema.json"
      }
    }
  }
}
