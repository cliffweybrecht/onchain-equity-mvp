{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grant-audit-transparency-checkpoint-finalization-policy-v1.schema.json",
  "title": "Grant Audit Transparency Checkpoint Finalization Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "policy_version",
    "created_at",
    "updated_at",
    "threshold",
    "authorized_witnesses"
  ],
  "properties": {
    "schema": {
      "const": "grant-audit-transparency-checkpoint-finalization-policy-v1"
    },
    "policy_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "threshold": {
      "type": "integer",
      "minimum": 1
    },
    "authorized_witnesses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "witness_id",
          "display_name",
          "public_key_pem_path",
          "public_key_fingerprint_sha256"
        ],
        "properties": {
          "witness_id": {
            "type": "string",
            "minLength": 1
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "public_key_pem_path": {
            "type": "string",
            "minLength": 1
          },
          "public_key_fingerprint_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
