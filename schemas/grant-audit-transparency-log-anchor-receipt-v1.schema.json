{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Grant Audit Transparency Log Anchor Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "created_at",
    "network",
    "anchor_contract",
    "log",
    "transaction",
    "event"
  ],
  "properties": {
    "schema": {
      "const": "grant-audit-transparency-log-anchor-receipt-v1"
    },
    "version": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "chain_id"],
      "properties": {
        "name": { "type": "string" },
        "chain_id": { "type": "integer" }
      }
    },
    "anchor_contract": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "log": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "entry_count",
        "head_entry_hash",
        "log_root"
      ],
      "properties": {
        "path": { "type": "string" },
        "entry_count": { "type": "integer", "minimum": 1 },
        "head_entry_hash": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        },
        "log_root": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        }
      }
    },
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hash",
        "block_number",
        "block_hash",
        "transaction_index",
        "status"
      ],
      "properties": {
        "hash": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        },
        "block_number": {
          "type": "string"
        },
        "block_hash": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        },
        "transaction_index": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "log_index",
        "anchored_at_block",
        "anchored_at_timestamp",
        "anchorer"
      ],
      "properties": {
        "name": { "type": "string" },
        "log_index": { "type": "string" },
        "anchored_at_block": { "type": "string" },
        "anchored_at_timestamp": { "type": "string" },
        "anchorer": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        }
      }
    }
  }
}
