{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grant-audit-transparency-log-fixture-v1.schema.json",
  "title": "Grant Audit Transparency Log Fixture v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "fixture_version",
    "fixture_id",
    "created_at",
    "description",
    "transitions",
    "log"
  ],
  "properties": {
    "schema": {
      "const": "grant-audit-transparency-log-fixture-v1"
    },
    "fixture_version": {
      "type": "string"
    },
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "old_size",
          "new_size"
        ],
        "properties": {
          "old_size": {
            "type": "integer",
            "minimum": 1
          },
          "new_size": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "log": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "log_version",
        "created_at",
        "updated_at",
        "entry_count",
        "head_entry_hash",
        "log_root",
        "entries"
      ],
      "properties": {
        "schema": {
          "const": "grant-audit-transparency-log-v1"
        },
        "log_version": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "entry_count": {
          "type": "integer",
          "minimum": 1
        },
        "head_entry_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "log_root": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "schema",
              "entry_version",
              "index",
              "appended_at",
              "packet_ref",
              "packet_hash",
              "previous_entry_hash",
              "previous_cumulative_root",
              "entry_hash",
              "cumulative_root"
            ],
            "properties": {
              "schema": {
                "const": "grant-audit-transparency-log-entry-v1"
              },
              "entry_version": {
                "type": "string"
              },
              "index": {
                "type": "integer",
                "minimum": 0
              },
              "appended_at": {
                "type": "string",
                "format": "date-time"
              },
              "packet_ref": {
                "type": "string"
              },
              "packet_hash": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "previous_entry_hash": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "previous_cumulative_root": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "entry_hash": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "cumulative_root": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          }
        }
      }
    }
  }
}
