{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Grant Audit Transparency Checkpoint External Anchor v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "manifest_version",
    "checkpoint_hash",
    "transparency_log_root",
    "checkpoint_witnesses_hash",
    "checkpoint_finalization_hash",
    "anchor_count",
    "anchors",
    "anchor_set_hash",
    "external_anchor_hash"
  ],
  "properties": {
    "schema": {
      "const": "grant-audit-transparency-checkpoint-external-anchor-v1"
    },
    "manifest_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "checkpoint_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "transparency_log_root": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "checkpoint_witnesses_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "checkpoint_finalization_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "checkpoint_rebinding_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "anchor_count": {
      "type": "integer",
      "minimum": 1
    },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "grant-audit-transparency-checkpoint-external-anchor-entry-v1.schema.json"
      }
    },
    "anchor_set_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "external_anchor_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
